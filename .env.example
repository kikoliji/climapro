# ─── Firebase ────────────────────────────────────────────────────────────────
# Copia aquest fitxer com .env.local i omple els valors reals
# Mai afegeixis .env.local al repositori git

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── FCM ─────────────────────────────────────────────────────────────────────
VITE_FIREBASE_VAPID_KEY=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD=
VITE_CLOUDINARY_PRESET=

# ─── Gmail API (OAuth2) ───────────────────────────────────────────────────────
# 1. Ves a GCP Console > APIs & Services > Credentials
# 2. Activa l'API "Gmail API" per al projecte Firebase
# 3. Crea un "OAuth 2.0 Client ID" de tipus "Web application"
# 4. Afegeix l'origen autoritzat (ex. http://localhost:5173 i el domini de producció)
VITE_GOOGLE_CLIENT_ID=
